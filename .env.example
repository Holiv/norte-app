# Supabase — Fase 1
# Painel do projeto Supabase > Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Variáveis usadas a partir da Fase 2, deixe em branco por enquanto ---

# Supabase service_role key — usada só em Vercel Functions (api/), nunca no frontend
# SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — extração via visão do comprovante/extrato (Fase 2)
# ANTHROPIC_API_KEY=

# Token da brapi.dev, se exigido (Fase 4)
# BRAPI_TOKEN=
